# Local development values. Never reuse this secret in production.
SECRET_KEY=change-me-to-a-long-random-development-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: leave DATABASE_URL commented out to use SQLite locally.
# Production should set this to the PostgreSQL URL supplied by the host.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/immanuella_os

# Production example values (set these in the hosting platform, not this file):
